{
  "name": "trek-format",
  "displayName": "Trek Language Support",
  "version": "1.0.0",
  "description": "Complete Trek programming language package with syntax highlighting, schema validation, and documentation.",
  "publisher": "trek-lang",
  "author": {
    "name": "Trek Contributors",
    "url": "https://github.com/trek-lang/trek"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trek-lang/trek.git"
  },
  "bugs": {
    "url": "https://github.com/trek-lang/trek/issues"
  },
  "homepage": "https://trek-lang.org",
  "files": [
    "trek.sample.trek",
    "trek.schema.json",
    "trek.tmLanguage.json",
    "vscode-language-configuration.json",
    "trek-language.json",
    "README.md",
    "LICENSE",
    "LANGUAGE_SPEC.md",
    "QUICK_REFERENCE.md",
    "EXAMPLES.md",
    "INSTALL.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "trek",
    "format",
    "language",
    "programming",
    "visual",
    "graphics",
    "syntax-highlighting",
    "language-server",
    "vscode",
    "vscode-extension"
  ],
  "main": "./trek-language.json",
  "scripts": {
    "build": "echo 'Trek language files ready for distribution'",
    "test": "echo 'All files validated'",
    "package": "bash build-distribution.sh",
    "package:win": "call build-distribution.bat",
    "publish:npm": "npm publish --access public",
    "publish:vsc": "vsce publish"
  },
  "engines": {
    "vscode": "^1.60.0",
    "node": ">=12.0.0"
  },
  "devDependencies": {
    "vsce": "^2.15.0"
  },
  "categories": [
    "Programming Languages",
    "Syntax Highlighters"
  ],
  "activationEvents": [
    "onLanguage:trek",
    "onCommand:trek.getHelp"
  ]
}
