        ],
        "configuration": "./vscode-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "trek",
        "scopeName": "source.trek",
        "path": "./trek.tmLanguage.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trek-lang/trek.git"
  },
  "bugs": {
    "url": "https://github.com/trek-lang/trek/issues"
